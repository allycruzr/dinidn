# ============================================
# FRONTEND (exposed to client via Vite)
# ============================================
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# BACKEND ONLY — NEVER prefix with VITE_
# These go to Supabase Vault for Edge Functions.
# ============================================
BELVO_SANDBOX_SECRET_ID=
BELVO_SANDBOX_SECRET_PASSWORD=
BELVO_PROD_SECRET_ID=
BELVO_PROD_SECRET_PASSWORD=
BELVO_ENV=sandbox
